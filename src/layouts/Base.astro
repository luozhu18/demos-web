---
// src/layouts/Base.astro
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  isHome?: boolean;
}

const { title, isHome = false } = Astro.props;
---

<!doctype html>
<html lang="en"> 
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

    <style is:global>
      /* =========================================
         1. 基础重置与强制字体
         ========================================= */
      :root {
        --color-bg: #ffffff;
        --color-fg: #000000;
        --color-muted: #666666;
        --space-md: 2rem;
        --space-sm: 1rem;
        --nav-height: 100px;
        --font-main: 'Space Mono', monospace;
      }

      *, *::before, *::after { 
        box-sizing: border-box; 
      }

      html, body, div, p, h1, h2, h3, h4, h5, h6, span, a, li, ul, ol, nav, main, section, article, button, input {
        font-family: var(--font-main) !important;
      }

      @media (pointer: fine) {
        * { cursor: none !important; }
      }
      
      html, body { 
        margin: 0; padding: 0; 
        background-color: var(--color-bg); 
        color: var(--color-fg); 
        -webkit-font-smoothing: antialiased; 
      }
      
      a { text-decoration: none; color: inherit; }

      h1, h2, h3, .brand-name { 
        letter-spacing: -0.05em; 
      }

      .justify-block, .justify-block p, article p, .project-desc p {
        font-size: 0.75rem !important; 
        line-height: 1.6 !important;
        text-align: justify !important;
        text-justify: inter-word !important;
        hyphens: auto !important;
        -webkit-hyphens: auto !important;
        margin-bottom: 1rem;
      }

      /* =========================================
         2. 自定义鼠标光标
         ========================================= */
      #global-cursor {
        position: fixed; top: 0; left: 0;
        width: 12px; height: 12px;
        background-color: #000; border-radius: 50%;
        pointer-events: none; z-index: 999999;
        transform: translate(-50%, -50%);
        transition: width 0.2s, height 0.2s, background-color 0.2s;
      }

      @media (max-width: 768px) {
        #global-cursor { display: none !important; }
      }

      /* =========================================
         3. 导航栏布局重构
         ========================================= */
      .global-nav {
        position: fixed; top: 0; left: 0; width: 100%; 
        height: var(--nav-height);
        
        /* 桌面端：完全透明，去掉模糊效果 */
        background-color: transparent;
        backdrop-filter: none;
        
        display: flex; 
        justify-content: space-between; 
        align-items: center;
        padding: 0 var(--space-md);
        z-index: 1200;
      }

      .brand-group { 
        display: flex; 
        flex-direction: column; 
        align-items: flex-start; 
      }
      .brand-name { font-size: 2.8rem; font-weight: 700; line-height: 0.9; }
      .brand-subtitle { font-size: 0.8rem; letter-spacing: 0.1em; color: var(--color-muted); text-transform: uppercase; margin-top: 4px; }
      
      .desktop-only { display: flex; gap: 0.8rem; }
      
      .nav-pill {
        font-size: 0.75rem; font-weight: 500; letter-spacing: 0.05em; 
        text-transform: uppercase; border: 1px solid var(--color-fg); 
        border-radius: 999px; padding: 0.5rem 1.2rem; 
        transition: all 0.3s ease; 
        background-color: #fff; 
      }
      .nav-pill:hover { background-color: var(--color-fg); color: #fff; }

      .hamburger-button, .mobile-menu-overlay { display: none; }

      /* =========================================
         4. 手机端适配
         ========================================= */
      @media (max-width: 768px) {
        .global-nav { 
          justify-content: center; 
          height: 70px; 
          padding: 0 var(--space-sm);
          
          /* 👇 核心修改：仅在手机端恢复白底和毛玻璃模糊效果 👇 */
          background-color: rgba(255, 255, 255, 0.95);
          backdrop-filter: blur(8px);
          -webkit-backdrop-filter: blur(8px); /* 兼容苹果手机 */
        }

        .brand-group { 
          align-items: center; 
        }
        
        .brand-name { font-size: 2rem; }
        .brand-subtitle { font-size: 0.5rem; text-align: center; }
        .desktop-only { display: none; }

        .hamburger-button {
          display: block; position: absolute; left: var(--space-sm);
          top: 50%; transform: translateY(-50%);
          background: none; border: none; padding: 5px; z-index: 1300;
        }
        .hamburger-box { display: block; width: 20px; height: 14px; position: relative; } 
        .hamburger-inner { top: 50%; margin-top: -1px; width: 20px; height: 1.5px; background-color: #000; position: absolute; transition: transform 0.2s ease; }
        .hamburger-inner::before, .hamburger-inner::after { content: ""; width: 20px; height: 1.5px; background-color: #000; position: absolute; transition: transform 0.2s ease; }
        .hamburger-inner::before { top: -6px; }
        .hamburger-inner::after { bottom: -6px; }

        .is-active .hamburger-inner { background-color: transparent; }
        .is-active .hamburger-inner::before { top: 0; transform: rotate(45deg); }
        .is-active .hamburger-inner::after { bottom: 0; transform: rotate(-45deg); }

        .mobile-menu-overlay {
          display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100vh; 
          background: var(--color-bg); 
          z-index: 1050; flex-direction: column; 
          justify-content: flex-start; align-items: flex-start; 
          padding-top: 80px; padding-left: var(--space-sm); 
          opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }
        .mobile-menu-overlay.is-open { opacity: 1; pointer-events: auto; }
        .menu-content { display: flex; flex-direction: column; gap: 0.8rem; }
        .mobile-menu-link { 
          font-size: 0.75rem; font-weight: 700; border: 1px solid var(--color-fg); 
          border-radius: 999px; padding: 0.4rem 1rem; background-color: #fff;
        }
      }
    </style>
  </head>
  
  <body>
    <div id="global-cursor"></div>
    
    {!isHome && (
      <>
        <nav class="global-nav">
          <button id="mobile-menu-trigger" class="hamburger-button">
            <span class="hamburger-box"><span class="hamburger-inner"></span></span>
          </button>

          <a href="/" class="brand-group">
            <span class="brand-name">DEMOS.</span>
            <span class="brand-subtitle">DEMOSTRATE, DEMOLISH, "DEMOS".</span>
          </a>

          <div class="nav-right desktop-only">
            <a href="/architecture" class="nav-pill">ARCHITECTURE</a>
            <a href="/photography" class="nav-pill">PHOTOGRAPHY</a>
          </div>
        </nav>

        <div id="mobile-menu-overlay" class="mobile-menu-overlay">
          <div class="menu-content">
            <a href="/architecture" class="mobile-menu-link">ARCHITECTURE</a>
            <a href="/photography" class="mobile-menu-link">PHOTOGRAPHY</a>
          </div>
        </div>
      </>
    )}

    <slot />

    <script is:inline>
      const initScripts = () => {
        const cursor = document.getElementById('global-cursor');
        if (cursor && window.innerWidth > 768) {
          document.onmousemove = (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
          };
          document.querySelectorAll('a, button').forEach(el => {
            el.onmouseenter = () => { cursor.style.width = '30px'; cursor.style.height = '30px'; cursor.style.mixBlendMode = 'difference'; cursor.style.backgroundColor = '#fff'; };
            el.onmouseleave = () => { cursor.style.width = '12px'; cursor.style.height = '12px'; cursor.style.mixBlendMode = 'normal'; cursor.style.backgroundColor = '#000'; };
          });
        }

        const btn = document.getElementById('mobile-menu-trigger');
        const overlay = document.getElementById('mobile-menu-overlay');
        if (btn && overlay) {
          btn.onclick = () => {
            btn.classList.toggle('is-active');
            overlay.classList.toggle('is-open'); 
          };
          overlay.onclick = (e) => {
            if (e.target.tagName === 'A' || e.target === overlay) {
              overlay.classList.remove('is-open');
              btn.classList.remove('is-active');
            }
          };
        }
      };
      initScripts();
      document.addEventListener('astro:page-load', initScripts);
    </script>
  </body>
</html>