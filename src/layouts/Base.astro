---
// src/layouts/Base.astro
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  isHome?: boolean;
}

const { title, isHome = false } = Astro.props;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <ClientRouter />

    <style is:global>
      /* =========================================
         1. 基础全局变量与重置
         ========================================= */
      :root {
        --color-bg: #ffffff;
        --color-fg: #000000;
        --color-muted: #666666;
        --space-md: 2rem;
        --space-sm: 1rem;
        --nav-height: 100px;
      }

      @media (pointer: fine) {
        * { cursor: none !important; }
      }
      
      html, body { 
        margin: 0; padding: 0; 
        font-family: monospace; 
        background-color: var(--color-bg); 
        color: var(--color-fg); 
        box-sizing: border-box; 
      }
      
      *, *::before, *::after { box-sizing: inherit; }
      a { text-decoration: none; color: inherit; }

      h1, h2, h3, .brand-name { letter-spacing: -0.05em; }

      /* =========================================
         2. 自定义鼠标光标
         ========================================= */
      #global-cursor {
        position: fixed; top: 0; left: 0;
        width: 12px; height: 12px;
        background-color: #000; border-radius: 50%;
        pointer-events: none; z-index: 999999;
        transform: translate(-50%, -50%);
        transition: width 0.2s, height 0.2s, background-color 0.2s;
      }

      @media (max-width: 768px) {
        #global-cursor { display: none !important; }
      }

      /* =========================================
         3. 桌面端导航栏样式
         ========================================= */
      .global-nav {
        position: fixed; top: 0; left: 0; width: 100%; 
        height: var(--nav-height);
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        display: flex; justify-content: space-between; align-items: center;
        padding: 0 var(--space-md);
        z-index: 1200; /* 👈 这里改成 1200 */
      }

      .brand-group { display: flex; flex-direction: column; }
      .brand-name { font-size: 3rem; font-weight: 900; line-height: 0.9; }
      .brand-subtitle { font-size: 0.85rem; letter-spacing: 0.12em; color: var(--color-muted); text-transform: uppercase; margin-top: 4px; }
      
      .desktop-only { display: flex; gap: 0.8rem; }
      
      .nav-pill {
        font-size: 0.85rem; font-weight: 500; letter-spacing: 0.05em; 
        text-transform: uppercase; border: 1px solid var(--color-fg); 
        border-radius: 999px; padding: 0.5rem 1.2rem; 
        transition: all 0.3s ease; background-color: #fff;
      }
      .nav-pill:hover { background-color: var(--color-fg); color: #fff; }

      .hamburger-button, .mobile-menu-overlay { display: none; }

      /* =========================================
         4. 手机端适配 (药丸悬浮版)
         ========================================= */
      @media (max-width: 768px) {
        .global-nav {
          justify-content: center; 
          padding: 0 var(--space-sm);
          height: 70px; /* 导航栏稍微改矮一点 */
        }

        /* 1. 缩小 Logo 和副标题 */
        .brand-name { font-size: 2.2rem; } /* 缩小主标题 */
        .brand-group.centered-logo { align-items: center; margin-top: 4px; }
        .brand-subtitle { font-size: 0.55rem; margin-top: 4px; letter-spacing: 0.08em; }

        .desktop-only { display: none; }

        /* 2. 缩小汉堡按钮 */
        .hamburger-button {
          display: block; position: absolute; left: var(--space-sm);
          top: 50%; transform: translateY(-50%);
          background: none; border: none; padding: 5px; z-index: 1100;
        }
        .hamburger-box { display: block; width: 20px; height: 14px; position: relative; } /* 缩小尺寸 */
        .hamburger-inner, .hamburger-inner::before, .hamburger-inner::after {
          width: 20px; height: 1.5px; background-color: #000; position: absolute; /* 线条变细变短 */
          transition: transform 0.2s ease, opacity 0.2s ease;
        }
        .hamburger-inner { top: 50%; margin-top: -0.75px; }
        .hamburger-inner::before { content: ""; top: -6px; }
        .hamburger-inner::after { content: ""; bottom: -6px; }

        .is-active .hamburger-inner { transform: rotate(45deg); }
        .is-active .hamburger-inner::before { opacity: 0; }
        .is-active .hamburger-inner::after { transform: rotate(-90deg); bottom: 0; }

        /* 3. 悬浮菜单底板（透明无白底，靠左上对齐） */
        .mobile-menu-overlay {
          display: flex; position: fixed; top: 0; left: 0; 
          width: 100%; height: 100vh; 
          background: transparent; /* 核心：完全透明 */
          z-index: 1050; 
          flex-direction: column; 
          justify-content: flex-start; /* 靠上对齐 */
          align-items: flex-start;     /* 靠左对齐 */
          padding-top: 80px;           /* 给顶部的导航栏留出空间 */
          padding-left: var(--space-sm); /* 和左侧汉堡按钮对齐 */
          opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }

        .mobile-menu-overlay.is-open {
          opacity: 1; pointer-events: auto;
        }

        /* 4. 药丸选项样式 */
        .menu-content { 
          display: flex; flex-direction: column; gap: 0.8rem; text-align: left; 
        }
        .mobile-menu-link { 
          font-size: 0.75rem; font-weight: 500; letter-spacing: 0.05em; 
          text-transform: uppercase; 
          border: 1px solid var(--color-fg); 
          border-radius: 999px; 
          padding: 0.4rem 1rem; 
          background-color: #fff; /* 药丸必须要有白底，防止文字和背景图片糊在一起 */
          color: #000;
          box-shadow: 2px 2px 0 rgba(0,0,0,0.1);
        }
        .mobile-menu-link:active {
          background-color: var(--color-fg);
          color: #fff;
        }
      }
    </style>
  </head>
  
  <body>
    <div id="global-cursor"></div>
    
    {!isHome && (
      <>
        <nav class="global-nav">
          <button id="mobile-menu-trigger" class="hamburger-button">
            <span class="hamburger-box"><span class="hamburger-inner"></span></span>
          </button>

          <a href="/" class="brand-group centered-logo">
            <span class="brand-name">DEMOS.</span>
            <span class="brand-subtitle">DEMOSTRATE, DEMOLISH, "DEMOS".</span>
          </a>

          <div class="nav-right desktop-only">
            <a href="/architecture" class="nav-pill">ARCHITECTURE</a>
            <a href="/photography" class="nav-pill">PHOTOGRAPHY</a>
            </div>
        </nav>

        <div id="mobile-menu-overlay" class="mobile-menu-overlay">
          <div class="menu-content">
            <a href="/architecture" class="mobile-menu-link">ARCHITECTURE</a>
            <a href="/photography" class="mobile-menu-link">PHOTOGRAPHY</a>
            </div>
        </div>
      </>
    )}

    <slot />

    <script is:inline>
      const initScripts = () => {
        const cursor = document.getElementById('global-cursor');
        if (cursor && window.innerWidth > 768) {
          document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
          });

          document.querySelectorAll('a, button').forEach(el => {
            el.addEventListener('mouseenter', () => {
              cursor.style.width = '30px'; cursor.style.height = '30px';
              cursor.style.mixBlendMode = 'difference'; cursor.style.backgroundColor = '#fff';
            });
            el.addEventListener('mouseleave', () => {
              cursor.style.width = '12px'; cursor.style.height = '12px';
              cursor.style.mixBlendMode = 'normal'; cursor.style.backgroundColor = '#000';
            });
          });
        }

        const btn = document.getElementById('mobile-menu-trigger');
        const overlay = document.getElementById('mobile-menu-overlay');

        if (btn && overlay) {
          // 点击汉堡按钮开关
          btn.onclick = () => {
            btn.classList.toggle('is-active');
            overlay.classList.toggle('is-open'); 
          };

          // 核心优化：点击药丸链接，或者点击透明的空白处，都会自动关闭菜单
          overlay.onclick = (e) => {
            if (e.target.tagName === 'A' || e.target === overlay) {
              overlay.classList.remove('is-open');
              btn.classList.remove('is-active');
            }
          };
        }
      };

      initScripts();
      document.addEventListener('astro:page-load', initScripts);
    </script>
  </body>
</html>