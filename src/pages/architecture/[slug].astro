---
// src/pages/architecture/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const architectureEntries = await getCollection('architecture');
  return architectureEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// 自动扫描项目文件夹下的图片
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/content/architecture/**/*.{jpeg,jpg,png,webp,JPG,JPEG}');
const projectImageResolvers = Object.entries(allImages)
  .filter(([path]) => path.includes(`/src/content/architecture/${entry.id}/`))
  .filter(([path]) => !path.endsWith('cover.jpg')) 
  .map(([path, resolver]) => resolver());

const galleryImages = await Promise.all(projectImageResolvers);

// 数据变量映射
const projectName = entry.data.name || "Untitled";
const projectType = entry.data.type || "ARCHIVE";
const projectId = entry.data.id || "00";
const projectTitle = entry.data.title || projectName;
const description = entry.data.description || "";
---

<Base title={`${projectTitle} - DEMOS.`}>
  <main class="detail-container">
    <div class="ticket-group-detail">
      
      <div class="ticket-outer-border">
        <div class="ticket-inner-bg top-part-detail">
          
          <div class="card-header-detail text-label">
            <span>FIG {projectId} <br/> {projectName}</span>
            <span class="text-right">SYS. CONNECT <br/> {projectType}</span>
          </div>

          <div class="main-image-wrapper">
            <div class="corner-bracket tl"></div>
            <div class="corner-bracket tr"></div>
            <div class="corner-bracket bl"></div>
            <div class="corner-bracket br"></div>
            
            {entry.data.coverImage && (
              <Image 
                src={entry.data.coverImage} 
                alt={`Cover for ${projectTitle}`} 
                class="detail-main-img zoomable" 
                width={1920} 
              />
            )}
          </div>
          
          <div class="project-intro">
            <h1 class="project-title-large">{projectTitle}</h1>
            {description && <p class="project-desc-large">{description}</p>}
          </div>
          
        </div>
      </div>

      <div class="ticket-gap"></div>

      <div class="ticket-outer-border">
        <div class="ticket-inner-bg bottom-part-detail">
          
          <div class="prose">
            <Content />
          </div>

          {galleryImages.length > 0 && (
            <div class="auto-gallery">
              {galleryImages.map((img, index) => (
                <div class="gallery-item">
                  <div class="corner-bracket tl"></div>
                  <div class="corner-bracket tr"></div>
                  <div class="corner-bracket bl"></div>
                  <div class="corner-bracket br"></div>
                  
                  <Image 
                    src={img.default} 
                    alt={`${projectTitle} Gallery - ${index + 1}`} 
                    class="gallery-img zoomable" 
                    width={1920} 
                  />
                  
                  <div class="gallery-caption">
                     FIG {projectId}.{String(index + 1).padStart(2, '0')}
                  </div>
                </div>
              ))}
            </div>
          )}

          <div class="footer-dots">············</div>
        </div>
      </div>

    </div>
  </main>
</Base>

<style>
  .detail-container { width: 80%; padding: 180px var(--space-md) 5rem var(--space-md); margin: 0 auto; }
  .ticket-group-detail { display: flex; flex-direction: column; }
  .ticket-gap { height: 12px; } 

  .ticket-outer-border { background-color: var(--color-fg); padding: 1px; clip-path: polygon(15px 0, calc(100% - 15px) 0, 100% 15px, 100% calc(100% - 15px), calc(100% - 15px) 100%, 15px 100%, 0 calc(100% - 15px), 0 15px); }
  .ticket-inner-bg { background-color: var(--color-bg); clip-path: polygon(14px 0, calc(100% - 14px) 0, 100% 14px, 100% calc(100% - 14px), calc(100% - 14px) 100%, 14px 100%, 0 calc(100% - 14px), 0 14px); }

  .card-header-detail { display: flex; justify-content: space-between; padding: var(--space-md); border-bottom: 1px solid var(--color-fg); font-size: 0.75rem; text-transform: uppercase; line-height: 1.4; }
  .main-image-wrapper { position: relative; margin: var(--space-md); padding: 15px; }
  .detail-main-img { width: 100%; height: auto; display: block; cursor: zoom-in; }

  .corner-bracket { position: absolute; width: 20px; height: 20px; border: 1px solid var(--color-fg); }
  .tl { top: 0; left: 0; border-right: 0; border-bottom: 0; } .tr { top: 0; right: 0; border-left: 0; border-bottom: 0; } .bl { bottom: 0; left: 0; border-right: 0; border-top: 0; } .br { bottom: 0; right: 0; border-left: 0; border-top: 0; }

  .project-intro { padding: 0 var(--space-md) var(--space-md) var(--space-md); }
  .project-title-large { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; text-transform: uppercase; line-height: 1.1; }
  .project-desc-large { font-size: 1.1rem; color: var(--color-muted); max-width: 80%; line-height: 1.5; text-align: justify; }

  .bottom-part-detail { padding: var(--space-md); min-height: 400px; }
  .prose { font-size: 1rem; line-height: 1.7; color: var(--color-fg); margin-bottom: 3rem; text-align: justify; max-width: 800px; }
  
  .auto-gallery { display: flex; flex-direction: column; gap: 2rem; }
  .gallery-item { position: relative; padding: 15px; }
  .gallery-img { width: 100%; height: auto; display: block; cursor: zoom-in; }
  .gallery-caption { margin-top: 10px; font-size: 0.7rem; color: var(--color-muted); text-align: right; text-transform: uppercase;}
  
  .footer-dots { text-align: center; opacity: 0.2; letter-spacing: 10px; margin-top: 3rem; }

  @media (max-width: 768px) {
    .detail-container { width: 100%; padding: 100px 12px 24px 12px; }
    .project-title-large { font-size: 1.2rem !important; }
    .project-desc-large, .prose { font-size: 0.75rem !important; }
  }
</style>