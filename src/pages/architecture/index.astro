---
// src/pages/architecture/index.astro
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allProjects = await getCollection('architecture');
const projects = allProjects.sort((a, b) => parseInt(String(a.data.id)) - parseInt(String(b.data.id)));
---

<Base title="Architecture - DEMOS.">
  <main class="container">
  

    <section class="tech-grid">
      {projects.map((proj) => (
        
        /* 核心：整个卡片组是一个链接，内部通过 gap 切开成两半 */
        <a href={`/architecture/${proj.id}`} class="tech-ticket-group">
          
          <div class="ticket-outer-border">
            <div class="ticket-inner-bg top-part">
              
              <div class="card-header text-label">
                <span>PROJ {String(proj.data.id).padStart(3, '0')} <br/> {proj.data.name}</span>
                <span class="text-right">CATEGORY <br/> {proj.data.type}</span>
              </div>

              <div class="card-body">
                <div class="corner-bracket tl"></div>
                <div class="corner-bracket tr"></div>
                <div class="corner-bracket bl"></div>
                <div class="corner-bracket br"></div>
                
                <div class="image-inner">
                  {proj.data.coverImage ? (
                    <Image src={proj.data.coverImage} alt={proj.data.name} class="proj-img" />
                  ) : (
                    <div class="img-placeholder"></div>
                  )}
                </div>
              </div>

            </div>
          </div>

          <div class="ticket-outer-border">
            <div class="ticket-inner-bg bottom-part">
              
              <div class="footer-text">
                <h2 class="project-title">{proj.data.title}</h2>
                <p class="project-desc">{proj.data.description}</p>
              </div>
              <div class="more-dots">······</div>
              
            </div>
          </div>

        </a>

      ))}
    </section>
    
  </main>
</Base>

<style>
  .container {
    /* 将顶部的内边距强制设为 180px，右、下、左保持原样 */
    padding: 120px var(--space-md) var(--space-md) var(--space-md); 
    min-height: 100vh;
    background-color: var(--color-bg);
  }

  .nav-top {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--space-xl);
  }
  .nav-link {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* =========================================
     联动票据组 (控制上下票据的间隙)
     ========================================= */
  .tech-ticket-group {
    display: flex;
    flex-direction: column;
    /* 核心：物理切开的间隙，这就是图示中间断开的部分 */
    gap: 8px; 
    text-decoration: none;
    color: var(--color-fg);
    transition: transform 0.2s ease;
  }

  /* 鼠标悬停时，上下两部分作为一个整体浮起 */
  .tech-ticket-group:hover {
    transform: translateY(-5px);
  }

  /* =========================================
     双层倒角边框魔法 (四个角全部切除)
     ========================================= */
  
  /* 黑色外壳：充当 1px 边框 */
  .ticket-outer-border {
    background-color: var(--color-fg); 
    padding: 1px; /* 边框粗细 */
    /* 八边形剪裁：四个角均倒角 12px */
    clip-path: polygon(
      12px 0, calc(100% - 12px) 0, 
      100% 12px, 100% calc(100% - 12px), 
      calc(100% - 12px) 100%, 12px 100%, 
      0 calc(100% - 12px), 0 12px
    );
  }

  /* 白色内卡片：露出黑色边框 */
  .ticket-inner-bg {
    height: 100%;
    /* 内层倒角比外层小 1px，完美对齐 */
    clip-path: polygon(
      11px 0, calc(100% - 11px) 0, 
      100% 11px, 100% calc(100% - 11px), 
      calc(100% - 11px) 100%, 11px 100%, 
      0 calc(100% - 11px), 0 11px
    );
  }

  /* 上半部背景为纯白 */
  .top-part { background-color: var(--color-bg); }
  /* 下半部背景稍微加深一点点，增加层次感 */
  .bottom-part { background-color: #fafafa; }

  /* =========================================
     内部排版格式 (保持原样)
     ========================================= */
  
  .card-header {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm);
    border-bottom: 1px solid var(--color-fg);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    line-height: 1.4;
    text-transform: uppercase;
  }
  .text-right { text-align: right; }

  .card-body {
    position: relative;
    margin: var(--space-sm);
    padding: 12px;
    aspect-ratio: 4 / 5;
  }
  
  .corner-bracket {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-fg);
  }
  .tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
  .tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }
  .bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }
  .br { bottom: 0; right: 0; border-left: 0; border-top: 0; }

  .image-inner { width: 100%; height: 100%; }
  .proj-img { width: 100%; height: 100%; object-fit: cover; }
  .img-placeholder { width: 100%; height: 100%; background-color: #f4f4f4; }

  /* 底部文字票据排版 */
  .bottom-part {
    padding: var(--space-sm);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer-text { max-width: 85%; }
  .project-title {
    font-size: var(--text-lg);
    font-weight: 500;
    margin: 0 0 var(--space-xs) 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 1.5em;
  }
  .project-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
    line-height: 1.4;
  }
  
  .more-dots {
    writing-mode: vertical-rl;
    letter-spacing: 4px;
    opacity: 0.4;
    font-size: 10px;
    padding-bottom: 4px;
  }

  @media (max-width: 1024px) { .tech-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .tech-grid { grid-template-columns: 1fr; } }
</style>