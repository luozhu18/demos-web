---
// src/pages/architecture/index.astro
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// 获取所有项目
const allProjects = await getCollection('architecture');

// 根据 ID 字符串进行排序 (适应类似 "01", "02", "10" 的情况)
const projects = allProjects.sort((a, b) => {
  const idA = String(a.data.id || "");
  const idB = String(b.data.id || "");
  return idA.localeCompare(idB, undefined, { numeric: true, sensitivity: 'base' });
});
---

<Base title="Architecture Archive - DEMOS.">
  <main class="container">
  
    <section class="tech-grid">
      {projects.map((proj) => {
        // 安全获取变量，匹配截图字段
        const projectNameLabel = proj.data.name || "Untitled"; // 票据头部的名字
        const displayId = proj.data.id ? String(proj.data.id).padStart(3, '0') : "000"; // FIG ID
        const category = proj.data.type || "ARCHIVE"; // 票据头部的类型
        const projectTitleMain = proj.data.title || proj.data.name || "Project"; // 底部大标题
        const description = proj.data.description || ""; // 描述

        return (
          <a href={`/architecture/${proj.id}`} class="tech-ticket-group" title={`View ${projectTitleMain}`}>
            <div class="ticket-outer-border">
              <div class="ticket-inner-bg top-part">
                <div class="card-header text-label">
                  <span>PROJ {displayId} <br/> {projectNameLabel}</span>
                  <span class="text-right">CATEGORY <br/> {category}</span>
                </div>

                <div class="card-body">
                  <div class="corner-bracket tl"></div>
                  <div class="corner-bracket tr"></div>
                  <div class="corner-bracket bl"></div>
                  <div class="corner-bracket br"></div>
                  
                  <div class="image-inner">
                    {proj.data.coverImage ? (
                      <Image 
                        src={proj.data.coverImage} 
                        alt={`Cover image for ${projectTitleMain}`} 
                        class="proj-img" 
                      />
                    ) : (
                      <div class="img-placeholder"></div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="ticket-outer-border">
              <div class="ticket-inner-bg bottom-part">
                <div class="footer-text">
                  <h2 class="project-title">{projectTitleMain}</h2>
                  {description && <p class="project-desc">{description}</p>}
                </div>
                <div class="more-dots">······</div>
              </div>
            </div>
          </a>
        );
      })}
    </section>
    
  </main>
</Base>

<style>
  /* =========================================
     全局与桌面端样式 (Brutalist aesthetic)
     ========================================= */
  .container { padding: 120px var(--space-md) var(--space-md) var(--space-md); min-height: 100vh; background-color: var(--color-bg); }
  .tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .tech-ticket-group { display: flex; flex-direction: column; gap: 8px; text-decoration: none; color: var(--color-fg); transition: transform 0.2s ease; }
  .tech-ticket-group:hover { transform: translateY(-5px); }

  .ticket-outer-border { 
    background-color: var(--color-fg); 
    padding: 1px; 
    clip-path: polygon(12px 0, calc(100% - 12px) 0, 100% 12px, 100% calc(100% - 12px), calc(100% - 12px) 100%, 12px 100%, 0 calc(100% - 12px), 0 12px); 
  }
  .ticket-inner-bg { 
    height: 100%; 
    clip-path: polygon(11px 0, calc(100% - 11px) 0, 100% 11px, 100% calc(100% - 11px), calc(100% - 11px) 100%, 11px 100%, 0 calc(100% - 11px), 0 11px); 
  }

  .top-part { background-color: var(--color-bg); }
  /* ✅ 底部设计改为纯白背景 */
  .bottom-part { background-color: #ffffff; color: #000; } 

  /* 适配夜间模式的底色 (Brutalistic invert) */
  :root[data-theme="dark"] .bottom-part { background-color: #000; color: #fff; }

  .card-header { display: flex; justify-content: space-between; padding: var(--space-sm); border-bottom: 1px solid var(--color-fg); font-size: 0.65rem; text-transform: uppercase; line-height: 1.4; letter-spacing: 0.05em;}
  .card-body { position: relative; margin: var(--space-sm); padding: 12px; aspect-ratio: 4 / 5; }
  .corner-bracket { position: absolute; width: 12px; height: 12px; border: 1px solid var(--color-fg); }
  .tl { top: 0; left: 0; border-right: 0; border-bottom: 0; } .tr { top: 0; right: 0; border-left: 0; border-bottom: 0; } .bl { bottom: 0; left: 0; border-right: 0; border-top: 0; } .br { bottom: 0; right: 0; border-left: 0; border-top: 0; }
  .image-inner { width: 100%; height: 100%; overflow: hidden; }
  /* ✅ 移除了 grayscale(100%)，图片默认是原色 */
  .proj-img { width: 100%; height: 100%; object-fit: cover; transition: filter 0.3s ease; }
  
  .bottom-part { padding: var(--space-sm); display: flex; justify-content: space-between; align-items: flex-end; }
  .project-title { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: -0.05em; line-height: 1.1; }
  .project-desc { font-size: 0.7rem; line-height: 1.3; opacity: 0.8; text-align: justify; word-spacing: -0.05em; letter-spacing: -0.02em;}
  .more-dots { writing-mode: vertical-rl; letter-spacing: 4px; opacity: 0.4; font-size: 10px; }

  @media (max-width: 1024px) { .tech-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { 
    .tech-grid { grid-template-columns: 1fr; gap: 1rem; } 
    .project-title { font-size: 1.1rem; }
    .project-desc { font-size: 0.65rem; }
  }
</style>