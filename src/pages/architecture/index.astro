---
// src/pages/architecture/index.astro
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allProjects = await getCollection('architecture');
const projects = allProjects.sort((a, b) => parseInt(String(a.data.id)) - parseInt(String(b.data.id)));
---

<Base title="Architecture - DEMOS.">
  <main class="container">
  
    <section class="tech-grid">
      {projects.map((proj) => (
        
        <a href={`/architecture/${proj.id}`} class="tech-ticket-group">
          
          <div class="ticket-outer-border">
            <div class="ticket-inner-bg top-part">
              
              <div class="card-header text-label">
                <span>PROJ {String(proj.data.id).padStart(3, '0')} <br/> {proj.data.name}</span>
                <span class="text-right">CATEGORY <br/> {proj.data.type}</span>
              </div>

              <div class="card-body">
                <div class="corner-bracket tl"></div>
                <div class="corner-bracket tr"></div>
                <div class="corner-bracket bl"></div>
                <div class="corner-bracket br"></div>
                
                <div class="image-inner">
                  {proj.data.coverImage ? (
                    <Image src={proj.data.coverImage} alt={proj.data.name} class="proj-img" />
                  ) : (
                    <div class="img-placeholder"></div>
                  )}
                </div>
              </div>

            </div>
          </div>

          <div class="ticket-outer-border">
            <div class="ticket-inner-bg bottom-part">
              
              <div class="footer-text">
                <h2 class="project-title">{proj.data.title}</h2>
                <p class="project-desc">{proj.data.description}</p>
              </div>
              
              <div class="more-dots">······</div>
              
            </div>
          </div>

        </a>
      ))}
    </section>
    
  </main>
</Base>

<style>
  /* =========================================
     全局与桌面端样式
     ========================================= */
  .container {
    padding: 120px var(--space-md) var(--space-md) var(--space-md); 
    min-height: 100vh;
    background-color: var(--color-bg);
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .tech-ticket-group {
    display: flex;
    flex-direction: column;
    gap: 8px; 
    text-decoration: none;
    color: var(--color-fg);
    transition: transform 0.2s ease;
  }

  .tech-ticket-group:hover {
    transform: translateY(-5px);
  }

  .ticket-outer-border {
    background-color: var(--color-fg); 
    padding: 1px; 
    clip-path: polygon(
      12px 0, calc(100% - 12px) 0, 
      100% 12px, 100% calc(100% - 12px), 
      calc(100% - 12px) 100%, 12px 100%, 
      0 calc(100% - 12px), 0 12px
    );
  }

  .ticket-inner-bg {
    height: 100%;
    clip-path: polygon(
      11px 0, calc(100% - 11px) 0, 
      100% 11px, 100% calc(100% - 11px), 
      calc(100% - 11px) 100%, 11px 100%, 
      0 calc(100% - 11px), 0 11px
    );
  }

  .top-part { background-color: var(--color-bg); }
  .bottom-part { background-color: #fafafa; }

  .card-header {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm);
    border-bottom: 1px solid var(--color-fg);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    line-height: 1.4;
    text-transform: uppercase;
  }
  
  .text-right { text-align: right; }

  .card-body {
    position: relative;
    margin: var(--space-sm);
    padding: 12px;
    aspect-ratio: 4 / 5;
  }
  
  .corner-bracket {
    position: absolute; width: 12px; height: 12px; border: 1px solid var(--color-fg);
  }
  .tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
  .tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }
  .bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }
  .br { bottom: 0; right: 0; border-left: 0; border-top: 0; }

  .image-inner { width: 100%; height: 100%; }
  .proj-img { width: 100%; height: 100%; object-fit: cover; }
  .img-placeholder { width: 100%; height: 100%; background-color: #f4f4f4; }

  .bottom-part {
    padding: var(--space-sm);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 15px; 
  }

  .footer-text { 
    flex: 1; 
  }
  
  .project-title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: -0.05em;
  }
  
  .project-desc {
    font-size: 0.75rem; 
    line-height: 1.35; 
    letter-spacing: -0.04em; 
    word-spacing: -0.05em; 
    text-align: justify;
    text-justify: inter-word; 
    hyphens: auto;
    -webkit-hyphens: auto;
    margin: 0; 
  }
  
  .more-dots {
    writing-mode: vertical-rl;
    letter-spacing: 4px;
    opacity: 0.4;
    font-size: 10px;
    padding-bottom: 4px;
  }

  /* =========================================
     响应式适配 (平板与手机)
     ========================================= */
  @media (max-width: 1024px) { 
    .tech-grid { grid-template-columns: repeat(2, 1fr); } 
  }

  /* =========================================
     🌟 手机端专属适配 (适度放大，兼顾阅读体验)
     ========================================= */
  @media (max-width: 768px) { 
    .container {
      padding: 80px 12px 24px 12px; 
    }

    .tech-grid { 
      grid-template-columns: 1fr; 
      gap: 1.2rem; 
    }

    .card-header {
      font-size: 0.6rem; /* 稍微放大顶部标签 */
      line-height: 1.2;
    }

    .project-title {
      font-size: 1.1rem; /* 标题放大到 1.1rem */
      margin-bottom: 0.6rem;
    }

    .project-desc {
      font-size: 0.65rem; /* 正文放大，阅读更舒适 */
      line-height: 1.4; /* 行高稍微调松，防拥挤 */
      letter-spacing: -0.03em; 
      word-spacing: -0.04em;
    }

    .more-dots {
      font-size: 8px; 
      letter-spacing: 2px;
    }
  }
</style>