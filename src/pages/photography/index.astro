---
// src/pages/photography/index.astro
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';

// 1. 抓取图片字典 (三层文件夹: 大洲/地点/项目/图片)
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/photography/*/*/*/*.{jpeg,jpg,png,webp,JPG,JPEG}', 
  { eager: true }
);

// 2. 自动解析三层文件夹结构并识别横竖比例
const flattenedPhotos = Object.entries(allImages).map(([path, imageObj], index) => {
  const pathParts = path.split('/');
  
  const continent = pathParts[4]?.toUpperCase() || "UNKNOWN";
  const location = pathParts[5]?.toUpperCase() || "UNKNOWN"; 
  const projectName = pathParts[6]?.toUpperCase() || "UNTITLED";

  // 🔥 核心修改：利用 Astro 图片元数据识别横竖比例 🔥
  const metadata = imageObj.default;
  const isPortrait = metadata.height > metadata.width; // 竖图长 > 宽

  const photoId = `${projectName.toLowerCase().replace(/\s+/g, '-')}-${index}`;

  return {
    id: photoId,
    src: imageObj.default,
    caption: projectName,
    location: location,
    continent: continent,
    // 传给前端的比例标记
    orientation: isPortrait ? 'portrait' : 'landscape', 
  };
});

// 3. 生成连贯的 displayId
const photos = flattenedPhotos.map((photo, index) => ({
  ...photo,
  displayId: String(index + 1).padStart(3, '0')
}));

// 4. 提取 大洲 -> 地点 -> 项目 的树状结构 (保持不变)
const CONTINENTS = ['ASIA', 'EUROPE', 'NORTH AMERICA', 'AFRICA', 'OCEANIA', 'SOUTH AMERICA'];
const groupedProjects = CONTINENTS.map(continent => {
  const continentPhotos = photos.filter(p => p.continent === continent);
  if (continentPhotos.length === 0) return null;
  const uniqueLocations = [...new Set(continentPhotos.map(p => p.location))];
  return {
    continent,
    locations: uniqueLocations.map(locationName => {
      const locationPhotos = continentPhotos.filter(p => p.location === locationName);
      const uniqueProjectNames = [...new Set(locationPhotos.map(p => p.caption))];
      return {
        name: locationName,
        projects: uniqueProjectNames.map(projName => {
          const firstPhoto = locationPhotos.find(p => p.caption === projName);
          return { name: projName, targetId: firstPhoto?.id };
        })
      };
    })
  };
}).filter(group => group !== null);
---

<Base title="Photography - DEMOS.">
  <main class="photography-page-container">
    
    <nav class="photo-directory">
      <div class="directory-header">INDEX / LOCATIONS</div>
      <div class="directory-columns">
        {groupedProjects.map(group => (
          <div class="directory-group">
            <h2 class="continent-title">{group.continent}</h2>
            <ul class="location-list">
              {group.locations.map(loc => (
                <li>
                  <details class="location-details">
                    <summary class="location-summary">{loc.name}</summary>
                    <ul class="project-list">
                      {loc.projects.map(project => (
                        <li>
                          <a href={`#${project.targetId}`} class="project-link">
                            <span class="link-name">{project.name}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </nav>

    <section class="in-place-grid" id="photo-grid">
      {photos.map((photo) => (
        <div class="grid-item" id={photo.id} data-orientation={photo.orientation}>
          <div class="image-wrapper">
            <Image 
              src={photo.src} 
              alt={photo.caption} 
              class="photo-content" 
              width={1600} 
              format="webp" 
              quality={85} 
            />
            
            <div class="detail-overlay">
              <div class="overlay-top-left">
                <div class="project-identity">
                  <span class="photo-id">{photo.displayId}</span>
                  <span class="photo-name">{photo.caption}</span>
                </div>
              </div>

              <div class="overlay-top-right">
                <div class="location-tag">{photo.location}</div>
                <div class="location-tag">{photo.continent}</div>
              </div>

              <div class="corner-bracket tl"></div>
              <div class="corner-bracket tr"></div>
              <div class="corner-bracket bl"></div>
              <div class="corner-bracket br"></div>
            </div>
          </div>
        </div>
      ))}
    </section>
  </main>
</Base>

<style is:global>
  /* 强制 summary 使用 Space Mono (治愈强迫症) */
  .location-summary {
    font-family: 'Space Mono', monospace !important;
  }
</style>

<style>
  .photography-page-container {
    width: 100%;
    padding: 180px var(--space-md) 5rem var(--space-md);
    container-type: inline-size; 
  }

  /* 目录与折叠样式 */
  .photo-directory { margin-bottom: 6rem; font-family: monospace; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; }
  .directory-header { border-bottom: 1px solid var(--color-fg); padding-bottom: 8px; margin-bottom: 2rem; font-weight: bold; width: 100%; color: var(--color-muted); }
  /* ✅ 修改：使用 Grid 布局强制一行三列 */
  .directory-columns { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); /* 划分为等宽的 3 列 */
    gap: 3rem 1rem; /* 行间距 3rem，列间距缩小到 1rem 避免手机端拥挤 */
  }
  .directory-group { 
    display: flex; 
    flex-direction: column; 
    min-width: 0; /* 🌟 关键：去掉最小宽度限制，允许在手机端自动压缩 */
    word-break: break-word; /* 防止 "NORTH AMERICA" 这种长名字撑破格子 */
  }
  .continent-title { font-size: 11px; font-weight: bold; color: var(--color-fg); margin-bottom: 0.5rem; border-bottom: 1px dashed #ccc; padding-bottom: 4px; display: inline-block;}
  .location-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .location-details { transition: all 0.2s ease; }
  .location-summary {
    cursor: none; 
    font-weight: bold; opacity: 0.6; transition: opacity 0.2s ease;
    list-style: none; position: relative; padding-left: 0; display: flex; align-items: center; 
  }
  .location-summary::-webkit-details-marker { display: none; }
  .location-summary::after { content: '▾'; margin-left: 6px; font-size: 10px; transform: rotate(-90deg); transition: transform 0.2s ease; }
  .location-summary:hover { opacity: 1; }
  .location-details[open] .location-summary { opacity: 1; margin-bottom: 0.4rem; color: var(--color-fg); }
  .location-details[open] .location-summary::after { transform: rotate(0); }
  .project-list { list-style: none; padding: 0 0 0 10px; margin: 0; display: flex; flex-direction: column; gap: 0.3rem; border-left: 1px solid #eee; }
  .project-link { color: var(--color-fg); opacity: 0.4; transition: opacity 0.2s ease, transform 0.2s ease; text-decoration: none; display: inline-block; }
  .project-link:hover { opacity: 1; transform: translateX(4px); }

  /* =========================================
     网格核心布局
     ========================================= */
  .in-place-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    /* 默认格子是 4:5 的略微竖方形 */
    grid-auto-rows: calc(((100cqw - 5px) / 6) * 1.25);
    gap: 1px; 
    background-color: var(--color-line, #e0e0e0);
    border: 1px solid var(--color-line, #e0e0e0);
    grid-auto-flow: dense; 
  }

  .grid-item {
    background-color: var(--color-bg, #ffffff);
    grid-column: span 1;
    grid-row: span 1;
    position: relative;
    cursor: none; 
    transition: transform 0.1s ease;
    scroll-margin-top: 200px;
  }
  .grid-item:active { transform: scale(0.98); }
  
  /* 🔥 =========================================
     🔥 核心修改：区分横竖展开比例
     🔥 ========================================= */
  
  /* 1. 横图 (Landscape) 展开比例: 4x2 
     比例分析: (4 col * w) / (2 row * 1.25w) = 4 / 2.5 = 1.6 (接近 16:9) */
  .grid-item[data-orientation="landscape"].is-expanded {
    grid-column: span 4;
    grid-row: span 2;
  }

  /* 2. 竖图 (Portrait) 展开比例: 3x4 
     比例分析: (3 col * w) / (4 row * 1.25w) = 3 / 5 = 0.6 (标准竖图比例) */
  .grid-item[data-orientation="portrait"].is-expanded {
    grid-column: span 3;
    grid-row: span 3;
  }

  .image-wrapper { width: 100%; height: 100%; position: relative; overflow: hidden; background: #f4f4f4; }
  .photo-content { width: 100%; height: 100%; object-fit: cover; transition: filter 0.3s ease; }

  /* 沉浸式 Overlay */
  .detail-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    padding: 20px;
    display: flex; justify-content: space-between; align-items: flex-start;
    font-family: monospace; font-size: 11px; letter-spacing: 0.05em;
    color: #fff; mix-blend-mode: difference; z-index: 10;
    pointer-events: none; 
    opacity: 0; transition: opacity 0.4s ease; 
  }
  .grid-item.is-expanded .detail-overlay { opacity: 1; }
  .overlay-top-left { display: flex; flex-direction: column; gap: 4px; }
  .project-identity { display: flex; gap: 10px; font-weight: bold; text-transform: uppercase;}
  .photo-id { opacity: 0.6; }
  .overlay-top-right { text-align: right; display: flex; flex-direction: column; gap: 10px; }
  /* ✅ 修改：取消背景色，让文字继承反色效果 */
  .location-tag { 
    background: transparent; 
    color: #fff; 
    padding: 0; 
    font-weight: bold; 
    display: inline-block; 
    align-self: flex-end; 
  }
  .corner-bracket { position: absolute; width: 12px; height: 12px; border: 1px solid #fff; opacity: 0; transition: opacity 0.3s; }
  .grid-item.is-expanded .corner-bracket { opacity: 0.8; }
  .tl { top: 15px; left: 15px; border-right: 0; border-bottom: 0; }
  .tr { top: 15px; right: 15px; border-left: 0; border-bottom: 0; }
  .bl { bottom: 15px; left: 15px; border-right: 0; border-top: 0; }
  .br { bottom: 15px; right: 15px; border-left: 0; border-top: 0; }

 /* 响应式调整 */
  @media (max-width: 1024px) {
    /* 🔥 新增：大幅缩短平板和手机端的顶部留白，让其贴紧导航栏 */
    .photography-page-container {
      padding-top: 100px; /* 导航栏约 70px，留出 30px 的舒适呼吸感 */
      padding-bottom: 2rem;
    }
    
    .in-place-grid { 
      grid-template-columns: repeat(4, 1fr); 
      grid-auto-rows: calc(((100cqw - 3px) / 4) * 1.25);
    }
    /* 手机端横图展开：满宽 */
    .grid-item[data-orientation="landscape"].is-expanded { grid-column: span 4; grid-row: span 2; }
    /* 手机端竖图展开：3x3 */
    .grid-item[data-orientation="portrait"].is-expanded { grid-column: span 3; grid-row: span 3; }
    .detail-overlay { padding: 12px; }
    .detail-overlay { 
      font-size: 8px !important; 
      padding: 12px !important;
    }
    
    /* 缩小左侧编号和名称的间距 */
    .project-identity {
      gap: 6px;
    }

    /* 缩小右侧标签的内边距和标签之间的间距 */
    .location-tag { 
      padding: 2px 4px !important; 
      border-radius: 1px;
    }
    .overlay-top-right {
      gap: 5px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const grid = document.getElementById('photo-grid');
    if (!grid) return; 

    const cursor = document.getElementById('global-cursor');
    const toggleCursorHover = (isHover) => {
      if(!cursor) return;
      if(isHover) {
        cursor.classList.add('cursor-hover');
      } else {
        cursor.classList.remove('cursor-hover');
      }
    };

    grid.onmouseover = (e) => {
      if (e.target.closest('.grid-item')) toggleCursorHover(true);
    };
    grid.onmouseout = (e) => {
      if (e.target.closest('.grid-item')) toggleCursorHover(false);
    };

    document.querySelectorAll('summary').forEach(el => {
      el.onmouseenter = () => toggleCursorHover(true);
      el.onmouseleave = () => toggleCursorHover(false);
    });

    grid.onclick = (e) => {
      if(e.target.tagName === 'A') return;
      const item = e.target.closest('.grid-item');
      if (!item) return;
      const isExpanded = item.classList.contains('is-expanded');
      document.querySelectorAll('.grid-item.is-expanded').forEach(el => {
        el.classList.remove('is-expanded');
      });
      if (!isExpanded) {
        item.classList.add('is-expanded');
        setTimeout(() => {
          item.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 50); 
      }
    };

    document.querySelectorAll('.project-link').forEach(link => {
      link.onclick = (e) => {
        const href = link.getAttribute('href');
        if (!href || !href.startsWith('#')) return;
        const targetId = href.substring(1);
        const targetItem = document.getElementById(targetId);
        if (targetItem) {
          document.querySelectorAll('.grid-item.is-expanded').forEach(el => el.classList.remove('is-expanded'));
          targetItem.classList.add('is-expanded');
        }
      };
    });
  });
</script>