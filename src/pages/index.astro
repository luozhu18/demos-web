---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
---

<Base title="DEMOS." isHome={true}></>
  <main class="home">
    
    <nav class="nav">
      <a href="/architecture" class="nav-link">ARCHITECTURE</a>
      <a href="/photography" class="nav-link">PHOTOGRAPHY</a>
      <a href="/writings" class="nav-link">WRITINGS</a>
    </nav>

    <div class="hero-wrapper">
      
      <div class="bg-card-container">
        <div class="bg-card">
          <div class="bg-card-face bg-card-front"></div>
          <div class="bg-card-face bg-card-back"></div>
        </div>
      </div>

      <section class="hero-content">
        <h1 class="hero-title">DEMOS.</h1>
        <p class="hero-subtitle">DEMOSTRATE, DEMOLISH, "DEMOS".</p>
      </section>

    </div>

  </main>
</Base>

<style>
  .home {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background-color: var(--color-bg); /* 确保网页背景是纯白 */
  }

  /* =========================================
     1. 包装层：由文字内容撑开大小
     ========================================= */
  .hero-wrapper {
    position: relative;
    display: inline-block;
    padding: var(--space-xl) var(--space-xl); /* 控制卡片边缘超出文字多少 */
  }

  /* =========================================
     2. 3D 卡片：绝对定位，填满包装层
     ========================================= */
  .bg-card-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    perspective: 1500px;
    z-index: 0;
    pointer-events: none;
  }

  .bg-card {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    animation: flip-card 12s infinite linear;
  }

  .bg-card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 20px; /* 稍微硬朗一点的圆角 */
    border: 1px solid var(--color-fg);
  }

  /* 正面：白底黑线 */
  .bg-card-front {
    background-color: #ffffff;
    background-image: 
      linear-gradient(#e0e0e0 1px, transparent 1px),
      linear-gradient(90deg, #e0e0e0 1px, transparent 1px);
    background-size: 30px 30px;
    transform: rotateY(0deg) translateZ(1px);
  }

  /* 反面：黑底灰线 */
  .bg-card-back {
    background-color: #000000;
    border-color: #333;
    background-image: 
      linear-gradient(#222 1px, transparent 1px),
      linear-gradient(90deg, #222 1px, transparent 1px);
    background-size: 30px 30px;
    transform: rotateY(180deg) translateZ(1px);
  }

  @keyframes flip-card {
    0% { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
  }

  /* =========================================
     3. 核心效果：文字取反 (Mix Blend Mode)
     ========================================= */
  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    pointer-events: none;
    /* 关键：设置混合模式 */
    mix-blend-mode: difference; 
  }

  .hero-title {
    /* 必须设为纯白色，混合模式才会生效产生“取反”效果 */
    color: #ffffff; 
    font-size: var(--text-hero, clamp(4rem, 12vw, 12rem));
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.8;
    margin: 0;
    /* 移除之前的阴影，阴影会干扰混合模式 */
    text-shadow: none; 
  }

  .hero-subtitle {
    color: #ffffff; /* 同样设为白色 */
    margin-top: var(--space-md);
    font-size: var(--text-lg);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* =========================================
     其他 UI 元素
     ========================================= */
  .nav {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 100;
    display: flex;
    gap: var(--space-md);
  }

  .nav-link {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 2px solid var(--color-fg); 
    border-radius: 9999px;
    padding: 0.4rem 1.2rem;
    transition: all 0.3s ease;
  }

  .nav-link:hover {
    background-color: var(--color-fg);
    color: var(--color-bg);
  }
</style>