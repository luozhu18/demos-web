---
// src/pages/index.astro
import Base from '../layouts/Base.astro';
---

<Base title="DEMOS." isHome={true}>
  <main class="home">
    
    <div class="hero-wrapper">
      
      <div class="bg-card-container">
        <div class="bg-card">
          <div class="bg-card-face bg-card-front"></div>
          <div class="bg-card-face bg-card-back"></div>
        </div>
      </div>

      <section class="hero-content">
        <a href="/contact" class="hero-link">
          <h1 class="hero-title">DEMOS.</h1>
        </a>
        <p class="hero-subtitle">DEMOSTRATE, DEMOLISH, "DEMOS".</p>
      </section>

    </div>

    <nav class="home-nav">
      <a href="/architecture" class="home-pill">ARCHITECTURE</a>
      <a href="/photography" class="home-pill">PHOTOGRAPHY</a>
    </nav>

  </main>
</Base>

<style>
  .home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background-color: var(--color-bg, #ffffff);
    overflow: hidden;
  }

  /* =========================================
     1. 包装层 (约束 3D 卡片与文字)
     ========================================= */
  .hero-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4.5rem 3.5rem; /* 给 3D 卡片留出精确的边缘空间 */
    z-index: 10;
  }

  /* =========================================
     2. 3D 旋转卡片
     ========================================= */
  .bg-card-container {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    perspective: 1500px;
    z-index: 0;
    pointer-events: none;
  }

  .bg-card {
    width: 100%; height: 100%; position: relative;
    transform-style: preserve-3d;
    animation: flip-card 12s infinite linear;
  }

  .bg-card-face {
    position: absolute; width: 100%; height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 20px;
    border: 1px solid var(--color-fg, #000);
  }

  .bg-card-front {
    background-color: #ffffff;
    background-image: 
      linear-gradient(#e0e0e0 1px, transparent 1px),
      linear-gradient(90deg, #e0e0e0 1px, transparent 1px);
    background-size: 30px 30px;
    transform: rotateY(0deg) translateZ(1px);
  }

  .bg-card-back {
    background-color: #000000;
    border-color: #333;
    background-image: 
      linear-gradient(#222 1px, transparent 1px),
      linear-gradient(90deg, #222 1px, transparent 1px);
    background-size: 30px 30px;
    transform: rotateY(180deg) translateZ(1px);
  }

  @keyframes flip-card {
    0% { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
  }

  /* =========================================
     3. 取反文字特效 (绝对居中优化 + 视觉补偿)
     ========================================= */
  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.2rem; 
    mix-blend-mode: difference;
    pointer-events: none; 
  }

  .hero-link {
    pointer-events: auto; 
    display: inline-block;
    text-decoration: none;
  }

  .hero-title {
    color: #ffffff; 
    font-size: clamp(4rem, 15vw, 10rem); 
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.8;
    margin: 0;
    transition: opacity 0.3s ease;
    /* 🌟 核心修复1：抵消句号重量造成的视觉偏左 */
    transform: translateX(0.08em); 
  }

  .hero-link:hover .hero-title {
    opacity: 0.8; 
  }

  .hero-subtitle {
    color: #ffffff;
    margin: 0; 
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    line-height: 1;
    /* 🌟 核心修复2：副标题视觉居中微调 */
    transform: translateX(0.075em); 
  }

  /* =========================================
     4. 胶囊导航 (默认：桌面端右上角)
     ========================================= */
  .home-nav {
    position: absolute; 
    top: var(--space-md, 2rem);
    right: var(--space-md, 2rem);
    z-index: 100;
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  .home-pill {
    font-family: monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 1px solid #000;
    border-radius: 9999px;
    padding: 0.5rem 1.5rem;
    background-color: #fff;
    color: #000;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 2px 2px 0 rgba(0,0,0,0.1);
  }

  .home-pill:hover {
    background-color: #000;
    color: #fff;
  }

  /* =========================================
     5. 手机端专项布局重构
     ========================================= */
  @media (max-width: 768px) {
    /* 🌟 核心修复3：去掉强制宽度，改用自适应包裹 */
    .hero-wrapper {
      padding: 3rem 1.5rem; /* 减小左右内边距，让卡片变窄、修长 */
      /* width: 90%; <-- 已删除这行“罪魁祸首” */
    }
    
    .hero-title {
      font-size: 18vw; 
    }

    .hero-subtitle {
      font-size: 0.65rem;
      letter-spacing: 0.1em;
    }

    /* 手机端胶囊导航：到底部，变上下排列 */
    .home-nav {
      position: relative;
      top: auto;
      right: auto;
      margin-top: 2.5rem; 
      flex-direction: column; 
      align-items: center;
      gap: 0.8rem;
      z-index: 20;
    }

    .home-pill {
      font-size: 0.75rem;
      padding: 0.5rem 2rem; 
      min-width: 160px; 
      text-align: center;
    }
  }
</style>