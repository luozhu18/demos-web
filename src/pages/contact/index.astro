---
// src/pages/contact.astro
import Base from '../../layouts/Base.astro';
---

<Base title="CONTACT - DEMOS. ARCHIVE">
  <main class="contact-page-wrapper">
    
    <section class="mega-title-section">
      <h1 class="mega-title">DEMOS.</h1>
      <div class="cut-line top-line"></div>
      <div class="cut-line bottom-line"></div>
    </section>

    <div class="spacer"></div>

    <section class="bottom-archive-section">
      <div class="archive-table">
        
        <div class="manifest-cell">
          <h2 class="section-title">MANIFEST</h2>
          <div class="manifest-text" id="typewriter-target">
            <p><strong>"Demos"</strong> (pronounced DEM-ohs) refers to the common people—the populace, the citizenry—rooted in ancient Greek political thought.</p>
            <p><strong>Demonstrate</strong> is to explain, prove, and reveal. Each project engages society and everyday life as sites of observation, analysis, and response, examining how space structures behavior and how images register the latent tensions of reality.</p>
            <p><strong>Demolish</strong> is to unsettle fixed forms, contest normative conventions, and challenge inherited assumptions of function, order, and aesthetics. Through the dismantling of established frameworks, alternative languages and new spatial possibilities may emerge.</p>
            <p><strong>DEMOS</strong> is more than a name; it is a position. </p>
          </div>
        </div>

        <div class="contact-cell">
          <h2 class="section-title">CONTACT</h2>
          <div class="manifest-text contact-list">
            <p><strong>NAME</strong> [ WANG YIRAN ]</p>
            <p><strong>EMAIL</strong> [ demiarchi18@163.com ]</p>
            <p><strong>INSTAGRAM</strong> @s</p>
          </div>
        </div>

      </div>
    </section>
    
  </main>
</Base>

<style>
  .contact-page-wrapper {
    height: 100dvh; 
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 100px var(--space-md) var(--space-md) var(--space-md);
    background-color: #f4f4f4; 
    overflow: hidden; 
  }

  /* 标题区域 */
  .mega-title-section {
    flex-shrink: 0; 
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .mega-title {
    font-size: clamp(6rem, 15vw, 15rem); 
    font-weight: 900;
    line-height: 0.8;
    margin: 0;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    color: var(--color-fg);
  }

  .cut-line {
    position: absolute; left: 0; width: 100%; height: 6.5%; 
    background-color: #f4f4f4; z-index: 1;
  }
  .top-line { top: 37%; }
  .bottom-line { top: 61%; }

  /* 🌟 核心修改 1：占位容器 */
  .spacer {
    flex-grow: 1; /* 自动吸收所有剩余空间 */
    min-height: 1.5rem; /* 强制标题和框之间至少有 2rem 的物理距离 */
  }

  /* 底部档案表区域 */
  .bottom-archive-section {
    flex-shrink: 1; /* 内容多时允许缩小 */
    max-height: 80vh; /* 🌟 核心修改 2：限制框的高度，防止它顶到标题 */
    display: flex;
    min-height: 0; 
  }

  .archive-table {
    display: grid;
    grid-template-columns: 2fr 1fr; 
    width: 100%;
    border: 1px solid var(--color-fg);
    background-color: #f4f4f4;
  }

  .manifest-cell {
    padding: clamp(1.2rem, 3vw, 2.5rem);
    border-right: 1px solid var(--color-fg);
    display: flex;
    flex-direction: column;
    min-height: 0; 
    overflow: hidden;
  }

  .contact-cell {
    padding: clamp(1.2rem, 3vw, 2.5rem);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .section-title {
    font-size: clamp(1.2rem, 3vw, 2.5rem);
    font-weight: 900;
    line-height: 0.9;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    flex-shrink: 0; 
  }

  .manifest-text {
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    line-height: 1.5;
    text-align: justify;
    overflow-y: auto; /* 超出部分内部滑动 */
    padding-right: 10px;
  }

  .manifest-text::-webkit-scrollbar { width: 3px; }
  .manifest-text::-webkit-scrollbar-thumb { background: var(--color-fg); }

  .manifest-text p { margin-bottom: 1rem; }
  .manifest-text p:last-child { margin-bottom: 0; }

  .manifest-text strong {
    background-color: var(--color-fg); color: var(--color-bg);
    padding: 0 6px; margin-right: 4px; font-weight: 700;
  }

  .contact-list {
    display: flex; flex-direction: column;
    gap: 0.6rem; overflow: hidden; 
  }

  .contact-list p { margin-bottom: 0; display: flex; align-items: center; }

  /* 光标动画 */
  .typewriter-cursor {
    display: inline-block; width: 8px; height: 12px;
    background-color: var(--color-fg); margin-left: 2px; vertical-align: baseline;
  }
  .typewriter-cursor.blink { animation: cursor-blink 1s step-end infinite; }
  @keyframes cursor-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* 响应式适配 */
  @media (max-width: 1024px) {
    .archive-table { grid-template-columns: 1fr; grid-template-rows: auto auto; }
    .manifest-cell { border-right: none; border-bottom: 1px solid var(--color-fg); }
  }

  @media (max-width: 768px) {
    .contact-page-wrapper {
      padding: 90px 12px 12px 12px;
    }
    .mega-title { font-size: 16vw; }
    .bottom-archive-section { max-height: 100vh; } /* 进一步压低手机端高度 */
    .manifest-cell, .contact-cell { padding: 1rem; }
    .section-title { font-size: 1.2rem; margin-bottom: 0.8rem; }
    .manifest-text { font-size: 0.75rem; }
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const target = document.getElementById('typewriter-target');
    if (!target) return;
    if (target.dataset.typed === 'true') return;
    const textNodes = [];
    function getNodes(node) {
      if (node.nodeType === 3) { textNodes.push(node); } 
      else { for (let child of node.childNodes) { getNodes(child); } }
    }
    getNodes(target);
    const originalTexts = textNodes.map(n => n.nodeValue);
    textNodes.forEach(n => n.nodeValue = '');
    const cursor = document.createElement('span');
    cursor.className = 'typewriter-cursor';
    let nodeIndex = 0; let charIndex = 0;
    function type() {
      if (!document.getElementById('typewriter-target')) return;
      if (nodeIndex < textNodes.length) {
        const node = textNodes[nodeIndex];
        const text = originalTexts[nodeIndex];
        if (cursor.parentNode !== node.parentNode || cursor.previousSibling !== node) {
          node.parentNode.insertBefore(cursor, node.nextSibling);
        }
        if (charIndex < text.length) {
          node.nodeValue += text.charAt(charIndex);
          charIndex++;
          setTimeout(type, Math.random() * 6 + 2);
        } else { nodeIndex++; charIndex = 0; type(); }
      } else { target.dataset.typed = 'true'; cursor.classList.add('blink'); }
    }
    setTimeout(type, 400);
  });
</script>